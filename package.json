{
  "name": "muhaymen-portfolio",
  "private": true,
  "version": "1.0.0",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "electron:start": "cross-env NODE_ENV=development electron .",
    "start": "concurrently -k \"npm run dev\" \"wait-on tcp:5173 && npm run electron:start\"",
    "prepare:release": "node scripts/clean-release-artifacts.cjs",
    "prepare:win-codesign": "node scripts/prepare-win-codesign.cjs",
    "pack": "npm run build && npm run prepare:release && npm run prepare:win-codesign && electron-builder --dir",
    "dist": "npm run build && npm run prepare:release && npm run prepare:win-codesign && electron-builder"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.10",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.muhaymen.portfolio",
    "productName": "Muhaymen",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "portable",
      "icon": "src/assets/icon.ico",
      "signAndEditExecutable": false
    }
  }
}
